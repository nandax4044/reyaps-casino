# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The API URL of your Supabase project (e.g. https://your-project-id.supabase.co)
SUPABASE_URL=

# SUPABASE_KEY: The Secret service_role API key or Anon API key of your Supabase project
SUPABASE_KEY=

# SUPABASE_SERVICE_KEY: The service_role key for admin operations
SUPABASE_SERVICE_KEY=

# VITE_SUPABASE_URL: Frontend Supabase URL (required for image upload)
VITE_SUPABASE_URL=

# VITE_SUPABASE_KEY: Frontend Supabase key (required for image upload)
VITE_SUPABASE_KEY=
